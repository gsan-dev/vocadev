# =============== CONFIGURACIÓN BOT ===============
# Token secreto de tu bot de Discord (obtenlo en el portal de desarrolladores)
DISCORD_TOKEN=YOUR_TOKEN_HERE

# ID de tu usuario en Discord (a este ID le llegarán los mensajes)
TARGET_USER_ID=YOUR_USER_ID

# Puerto interno por donde escuchará el bot al webhook de Uptime Kuma (Mapeado y expuesto en el docker-compose)
WEBHOOK_PORT=15830
